# =============================================================================
# runners/go-libp2p/Dockerfile.linux
#
# go-libp2p CI runner — Linux
# Extends the base runner image with Go-specific dependencies.
#
# Build:
#   docker build --platform linux/amd64 \
#     -f runners/go-libp2p/Dockerfile.linux \
#     -t ghcr.io/py-libp2p-runners/runner-go-libp2p:linux-latest .
# =============================================================================

FROM ghcr.io/py-libp2p-runners/runner-base:linux-latest

ENV DEBIAN_FRONTEND=noninteractive

# Base image sets USER runner — switch back to root for package installs
USER root

# -----------------------------------------------------------------------------
# Go (latest stable)
# -----------------------------------------------------------------------------
ARG GO_VERSION=1.22.3

RUN curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz" \
    | tar -C /usr/local -xz

ENV PATH="/usr/local/go/bin:$PATH"
ENV GOPATH="/home/runner/go"
ENV PATH="/home/runner/go/bin:/usr/local/go/bin:$PATH"

# -----------------------------------------------------------------------------
# Common Go tools (install to a world-accessible path)
# -----------------------------------------------------------------------------
RUN mkdir -p /home/runner/go && \
    GOPATH=/home/runner/go go install golang.org/x/tools/cmd/goimports@latest && \
    GOPATH=/home/runner/go go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest && \
    chown -R runner:runner /home/runner/go

# -----------------------------------------------------------------------------
# Sanity checks
# -----------------------------------------------------------------------------
RUN go version && goimports -h 2>&1 | head -1

# Switch to non-root runner user
USER runner
